+protected boolean validPublicIdChar(int c) {
+    return
+        c == 0xA ||                     //<LF>
+        c == 0xD ||                     //<CR>
+        c == 0x20 ||                    //<SPACE>
+        (c >= '0' && c <= '9') ||       // Digits [0-9]
+        c == '-' ||                     // Hyphen
+        (c >= '@' && c <= 'Z') ||       //@[A-Z]
+        (c >= 'a' && c <= 'z') ||
+        c == '!' ||
+        (c >= 0x23 && c <= 0x25) ||     //#$%
+        (c >= 0x27 && c <= 0x2F) ||     //'()*+,-./
+        (c >= ':' && c <= ';') ||
+        c == '=' ||
+        c == '?' ||
+        c == '_';
+}
 

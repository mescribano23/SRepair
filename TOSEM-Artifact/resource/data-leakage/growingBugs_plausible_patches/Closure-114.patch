diff --git a/src/com/google/javascript/jscomp/NameAnalyzer.java b/src/com/google/javascript/jscomp/NameAnalyzer.java
index 0fc5ae8f..102fba8d 100644
--- a/src/com/google/javascript/jscomp/NameAnalyzer.java

+        private boolean isInConditionalExpression(Node n) {
+          Node parent = n.getParent();
+          while (parent != null) {
+            if (parent.isHook() || parent.isIf()) {
+              return true;
+            }
+            parent = parent.getParent();
+          }
+          return false;
+        }
+
+        private boolean isInCommaExpression(Node n) {
+          Node parent = n.getParent();
+          while (parent != null) {
+            if (parent.isComma()) {
+              return true;
+            }
+            parent = parent.getParent();
+          }
+          return false;
+        }

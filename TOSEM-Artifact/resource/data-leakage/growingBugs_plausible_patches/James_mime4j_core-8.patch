+    private static int findSplitIndex(String text, Charset charset) {
+        int splitIndex = text.length() / 2;
+        while (splitIndex > 0 && !isValidSplitPoint(text, splitIndex, charset)) {
+            splitIndex--;
+        }
+        return splitIndex;
+    }
+
+    private static boolean isValidSplitPoint(String text, int index, Charset charset) {
+        byte[] bytes1 = encode(text.substring(0, index), charset);
+        byte[] bytes2 = encode(text.substring(index), charset);
+        return (bytes1.length + bytes2.length) == encode(text, charset).length;
+    }

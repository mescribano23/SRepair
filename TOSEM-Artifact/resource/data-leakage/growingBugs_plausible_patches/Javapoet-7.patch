+private void emitModifiers(Set<Modifier> modifiers) throws IOException {
+  if (modifiers.isEmpty()) {
+    return; // No modifiers to process, return early.
+  }
+  if (!(modifiers instanceof EnumSet)) {
+    modifiers = EnumSet.copyOf(modifiers);

+    if (!json.containsKey("limit") || !json.containsKey("remaining") || !json.containsKey("reset")) {
+        throw new IllegalStateException("Required resource is absent");
+    }
+    final int limit = json.getInt("limit");
+    final int remaining = this.max - (limit - json.getInt("remaining"));
+    return Json.createObjectBuilder()
+        .add("limit", limit)
+        .add("remaining", remaining)
+        .add("reset", json.getInt("reset"))
+        .build();

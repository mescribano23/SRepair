+@Override
+public void add(
+    @NotNull(message = "User is never null") final String user)
+{
+    try {
+        this.request.method(Request.PUT)
+            .uri().path("/collaborators").path(user).back()
+            .fetch()
+            .as(RestResponse.class)
+            .assertStatus(HttpURLConnection.HTTP_NO_CONTENT);
+    } catch (IOException e) {
+        throw new IllegalStateException(String.format("Failed to add collaborator: %s", user), e);
     }

+public static boolean containsAny(CharSequence cs, char[] searchChars) {
+    if (isEmpty(cs) || ArrayUtils.isEmpty(searchChars)) {
+        return false;
+    }
+    
+    int searchLength = searchChars.length;
+    for (int i = 0; i < cs.length(); ) {
+        int cp = Character.codePointAt(cs, i); // Get the code point at the current position
+        for (int j = 0; j < searchLength; j++) {
+            if (searchChars[j] == cp || (Character.isSupplementaryCodePoint(cp) && j < searchLength - 1 && Character.toChars(cp)[0] == searchChars[j] && Character.toChars(cp)[1] == searchChars[j + 1])) {
+                return true;
+            }
+        }
+        i += Character.charCount(cp); // Move to the next character or surrogate pair
+    }
+    return false;
+}
 

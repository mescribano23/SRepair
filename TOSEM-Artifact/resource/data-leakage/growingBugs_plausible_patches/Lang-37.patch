+@SuppressWarnings("unchecked")
+public static <T> T[] addAll(T[] array1, T... array2) {
+    if (array1 == null) {
+        return clone(array2);
+    } else if (array2 == null) {
+        return clone(array1);
+    }
+    final Class<?> type1 = array1 != null ? array1.getClass().getComponentType() : null;
+    final Class<?> type2 = array2 != null ? array2.getClass().getComponentType() : null;
+
+    if (type1 != null && type2 != null && !type1.isAssignableFrom(type2) && !type2.isAssignableFrom(type1)) {
+        throw new IllegalArgumentException("Incompatible array types: " + type1.getName() + " and " + type2.getName());
     }
 
+    Class<?> commonType = type1 != null ? type1 : type2;
+    T[] joinedArray = (T[]) Array.newInstance(commonType, array1.length + array2.length);
+    System.arraycopy(array1, 0, joinedArray, 0, array1.length);
+    System.arraycopy(array2, 0, joinedArray, array1.length, array2.length);
+
+    return joinedArray;
+}

+public String[] getAllAddresses() {
+    int ct = getAddressCount();
+    if (ct == 0) {
+        return new String[0];
+    }
+    String[] addresses = new String[ct];
+    for (int add = low(), j=0; add <= high(); ++add, ++j) {
+        addresses[j] = format(toArray(add));
+    }
+    return addresses;

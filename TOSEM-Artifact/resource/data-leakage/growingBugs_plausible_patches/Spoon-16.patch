+public CtTypeReference<?> getSuperclass() {
+    CtType<T> t = getDeclaration();
+    if (t != null) {
+        return t.getSuperclass();
+    } else {
+        try {
+            Class<T> c = getActualClass();
+            Class<?> sc = c.getSuperclass();
+            if (sc == null) {
+                return null;
+            }
+            return getFactory().Type().createReference(sc);
+        } catch (final SpoonClassNotFoundException e) {
+            // Instead of rethrowing, log and return null, or a default superclass
+            if (getFactory().getEnvironment().getNoClasspath()) {
+                return null;
+            }
+            System.err.println("Class not found: " + getQualifiedName() + ". Returning Object as fallback.");
+            return getFactory().Type().createReference(Object.class); // Fallback
+        }
+    }
+}
 

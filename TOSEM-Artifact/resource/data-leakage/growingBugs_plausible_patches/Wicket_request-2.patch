+private static QueryParameter parseQueryParameter(final String qp, final Charset charset)
+{
+    int idxOfEquals = qp.indexOf('=');
+    if (idxOfEquals == -1)
+    {
+        // name => empty value
+        return new QueryParameter(decodeParameter(qp, charset), "");
+    }
+
+    String name = qp.substring(0, idxOfEquals);
+    String value = qp.substring(idxOfEquals + 1);
+    return new QueryParameter(decodeParameter(name, charset), decodeParameter(value, charset));
+}
 
